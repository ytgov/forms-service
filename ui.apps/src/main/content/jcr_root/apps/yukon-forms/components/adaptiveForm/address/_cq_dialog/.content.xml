<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0" xmlns:granite="http://www.adobe.com/jcr/granite/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:sling="http://sling.apache.org/jcr/sling/1.0"
    jcr:primaryType="nt:unstructured"
    jcr:title="\0"
    sling:resourceType="cq/gui/components/authoring/dialog">
    <content
        jcr:primaryType="nt:unstructured"
        sling:resourceType="granite/ui/components/coral/foundation/container">
        <items jcr:primaryType="nt:unstructured">
            <accordion
                jcr:primaryType="nt:unstructured"
                sling:resourceType="granite/ui/components/coral/foundation/accordion">
                <items jcr:primaryType="nt:unstructured">
                    <basic
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Basic"
                        sling:resourceType="granite/ui/components/coral/foundation/container"/>
                    <help
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Help Content"
                        sling:resourceType="granite/ui/components/coral/foundation/container"/>
                    <accessibility jcr:primaryType="nt:unstructured"/>
                    <patterns
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="granite/ui/components/coral/foundation/container"/>
                    <address
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Canada Post"
                        sling:resourceType="granite/ui/components/coral/foundation/container">
                        <items jcr:primaryType="nt:unstructured">
                            <searchLimit
                                granite:class="plainTextValue"
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/numberfield"
                                defaultValue="7"
                                fieldLabel="Search Limit"
                                max="10"
                                min="0"
                                name="./limit"/>
                            <fieldLine1
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Field Name Of Address Line 1"
                                fieldDescription="CSS class of the panel containing the address line 1 input."
                                defaultValue="addressLine1"
                                name="./fieldLine1"/>
                            <fieldLine2
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Field Name Of Address Line 2"
                                fieldDescription="CSS class of the panel containing the address line 2 input."
                                defaultValue="addressLine2"
                                name="./fieldLine2"/>
                            <fieldCity
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Field Name Of City"
                                fieldDescription="CSS class of the panel containing the city input."
                                defaultValue="city"
                                name="./fieldCity"/>
                            <fieldProvince
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Field Name Of Province"
                                fieldDescription="CSS class of the panel containing the province input."
                                defaultValue="province"
                                name="./fieldProvince"/>
                            <fieldPostalCode
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="granite/ui/components/coral/foundation/form/textfield"
                                fieldLabel="Field Name Of Postal Code"
                                fieldDescription="CSS class of the panel containing the postal code input."
                                defaultValue="postalCode"
                                name="./fieldPostalCode"/>
                        </items>
                    </address>
                </items>
            </accordion>
        </items>
    </content>
</jcr:root>
